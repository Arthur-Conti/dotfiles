{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "padding": {
            "top": 2
        },
        "color": {
            "1": "magenta", // Você pode mudar para uma cor fixa ou variável
            "2": "magenta"
        }
    },
    "display": {
        "separator": " 󰄛 ",
        "color": {
            "keys": "#a8c8ff",
            "title": "#b6c7e8"
        }
    },
    "modules": [
        "title",
        "separator",
        {
            "type": "os",
            "key": "󰣇 OS ",
            "keyColor": "#a8c8ff"
        },
        {
            "type": "kernel",
            "key": "󰒋 KRN",
            "keyColor": "#b6c7e8"
        },
        {
            "type": "packages",
            "key": "󰏖 PKG",
            "keyColor": "#f1affe"
        },
        {
            "type": "shell",
            "key": "󰞷 SHL",
            "keyColor": "#a8c8ff"
        },
        {
            "type": "wm",
            "key": "󱂬 WM ",
            "keyColor": "#b6c7e8"
        },
        {
            "type": "terminal",
            "key": "󰆍 TRM",
            "keyColor": "#f1affe"
        },
        {
            "type": "uptime",
            "key": "󰅐 UPT",
            "keyColor": "#a8c8ff"
        },
        "break",
        {
            "type": "colors",
            "symbol": "circle"
        }
    ]
}
